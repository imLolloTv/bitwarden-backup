BW_CLIENTID=client_id
BW_CLIENTSECRET=client_secret

# Bitwarden Secrets Manager
# Access token del machine account (obbligatorio)
BWS_ACCESS_TOKEN=access_token_machine_account

# ID del secret contenente la master password (obbligatorio)
BW_SECRET_ID=uuid-del-secret

# Server Secrets Manager (opzionale, per self-hosted)
# SM_BASE_URL=https://your-server.com

# Server Bitwarden (default: https://vault.bitwarden.com)
BW_SERVER=https://vault.bitwarden.com

# Crittografia AES-256 (opzionale)
ENCRYPTION_KEY=chiave_super_segreta_32_caratteri

# Webhook di notifica (opzionale)
WEBHOOK_URL=https://hook.example.com/bitwarden-backup
